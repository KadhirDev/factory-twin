{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Ingestion",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Total Telemetry Ingested",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(factory_twin_telemetry_ingested_total)",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Machines Online",
      "type": "stat",
      "targets": [
        { "expr": "factory_twin_machines_online_total", "legendFormat": "online", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Total Alerts Generated",
      "type": "stat",
      "targets": [
        { "expr": "sum(factory_twin_alerts_generated_total)", "legendFormat": "alerts", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.05 },
            { "color": "red", "value": 0.2 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "P95 Ingest Latency",
      "type": "stat",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(factory_twin_ingest_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "id": 10,
      "title": "Telemetry Ingestion Rate (per machine)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(factory_twin_telemetry_ingested_total[1m])", "legendFormat": "{{machine_id}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "id": 11,
      "title": "Ingest Latency Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(factory_twin_ingest_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(factory_twin_ingest_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(factory_twin_ingest_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 101,
      "title": "🌡 Sensor Readings",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "celsius", "custom": { "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 80 },
            { "color": "red", "value": 95 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "id": 20,
      "title": "Temperature per Machine",
      "type": "timeseries",
      "targets": [
        { "expr": "factory_twin_sensor_temperature_celsius", "legendFormat": "{{machine_id}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "id": 21,
      "title": "Vibration per Machine",
      "type": "timeseries",
      "targets": [
        { "expr": "factory_twin_sensor_vibration", "legendFormat": "{{machine_id}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "id": 22,
      "title": "RPM per Machine",
      "type": "timeseries",
      "targets": [
        { "expr": "factory_twin_sensor_rpm", "legendFormat": "{{machine_id}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 20   },
            { "color": "green",  "value": 40   }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "id": 23,
      "title": "Oil Level per Machine",
      "type": "timeseries",
      "targets": [
        { "expr": "factory_twin_sensor_oil_level_percent", "legendFormat": "{{machine_id}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 102,
      "title": "🚨 Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 28 },
      "id": 30,
      "title": "Alert Rate by Severity",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(factory_twin_alerts_generated_total[2m])", "legendFormat": "{{machine_id}} / {{severity}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["factory-twin"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Factory Twin — Operations",
  "uid": "factory-twin-ops",
  "version": 1
}